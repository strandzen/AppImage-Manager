# Maintainer: Herman Strandzen <strandzen@gmail.com>
pkgname=appimagemanager
pkgver=2.0.0
pkgrel=1
pkgdesc="KDE Plasma 6 utility for managing AppImage files"
arch=('x86_64')
url="https://github.com/strandzen/AppImage-Manager"
license=('GPL-2.0-or-later')
depends=(
    'kf6-config'
    'kf6-coreaddons'
    'kf6-crash'
    'kf6-dbusaddons'
    'kf6-iconthemes'
    'kf6-i18n'
    'kf6-kio'
    'kf6-notifications'
    'kf6-statusnotifieritem'
    'kirigami-addons'
    'libappimage'
    'qt6-base'
    'qt6-declarative'
    'qt6-svg'
)
makedepends=(
    'cmake'
    'extra-cmake-modules'
    'ninja'
    'qt6-tools'
)
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cmake -S "AppImage-Manager-$pkgver" -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -GNinja
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
}
